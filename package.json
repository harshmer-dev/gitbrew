{
  "name": "gitbrew",
  "version": "1.0.0",
  "description": "A cli tool to manage and get info from git and github to manage any project",
  "bin": {
    "gitbrew": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "keywords": [
    "git tool",
    "cli tool"
  ],
  "author": "Harsh Mer",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^7.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.5",
    "simple-git": "^3.36.0",
    "sparkly": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
